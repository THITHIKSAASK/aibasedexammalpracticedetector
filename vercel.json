{\n  "version": 2,\n  "builds": [\n    {\n      "src": "server.js",\n      "use": "@vercel/node"\n    },\n    {\n      "src": "public/**/*",\n      "use": "@vercel/static"\n    }\n  ],\n  "routes": [\n    {\n      "src": "/(.*)",\n      "dest": "server.js"\n    }\n  ],\n  "env": {\n    "DATABASE_URL": "your_production_database_url",\n    "API_KEY": "your_production_api_key"\n  },\n  "regions": [\n    "all"\n  ]\n}